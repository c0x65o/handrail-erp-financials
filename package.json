{
  "name": "@handrail/erp-financials",
  "version": "0.1.1",
  "description": "Provider-neutral ERP financial reporting kernel for canonical accounting facts, rollups, snapshots, and report APIs.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "sideEffects": false,
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
