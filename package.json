{
  "name": "@handrail/erp-financials",
  "version": "0.1.16",
  "description": "Provider-neutral ERP financial reporting kernel for canonical accounting facts, rollups, snapshots, and report APIs.",
  "type": "module",
  "license": "UNLICENSED",
  "private": false,
  "sideEffects": false,
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "contract:smoke": "vitest run test/normalized-quickbooks-contract-smoke.test.ts",
    "health:smoke": "vitest run test/health-contract.test.ts test/install-health.test.ts test/fixture-smoke-health.test.ts test/freshness-drilldown-health.test.ts test/future-erp-install-health-preflight.test.ts",
    "prepare": "npm run build",
    "sandbox:quickbooks:replay": "vitest run test/future-erp-sandbox-replay.test.ts",
    "typecheck:core-erp-imports": "tsc --noEmit -p tsconfig.core-erp-consumer.json",
    "typecheck:future-erp-imports": "tsc --noEmit -p tsconfig.future-erp-consumer.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  }
}
